# Bunu `brain.env` olarak kopyala. Backend baslangicta okur. (.gitignore'da.)
# Hangi degisken doluysa o ozellik AKTIF olur; bos birakirsan mock/kapali calisir.

# ---- AI ajani (biri yeterli; yoksa deterministik mock) ----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
# ANTHROPIC_API_KEY=
# BRAIN_AGENT_MODEL=claude-sonnet-4-6

# ---- WhatsApp Cloud API (Meta) — gelen webhook yaniti + sablon gonderme ----
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=        # webhook kurarken Meta'ya gireceğin token (sen belirle)

# ---- Meta Marketing API — harcama cek + butce yaz + Conversions API ----
META_TOKEN=
META_AD_ACCOUNT_ID=          # act_ onekini yazma
META_PIXEL_ID=
# Lead Ads webhook'un leadgen_id'den gercek lead (isim/telefon) cekmesi icin
# leads_retrieval izni olan bir token (genelde Page token). Bossa META_TOKEN kullanilir.
META_PAGE_TOKEN=

# ---- Google Ads API — gercek harcama cek + butce yaz + offline conversion ----
# Klinik refresh token'i panelden OAuth ile yakalanir (UI > Baglantilar > Google).
# Asagidakiler HESAP SEVIYESI; bunlar olmadan Google API her cagriyi reddeder.
GOOGLE_CLIENT_ID=            # OAuth app (nextjs-web/.env.local ile AYNI olmali)
GOOGLE_CLIENT_SECRET=        # OAuth app secret
GOOGLE_ADS_DEVELOPER_TOKEN=  # Google Ads > Tools > API Center (basvuru gerekir)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=# MCC/manager hesabi id'si (varsa; tiresiz). Bos = direkt hesap
GOOGLE_ADS_CONVERSION_ACTION=# offline conversion icin action resource adi (ops.)

# ---- Guvenlik & depo ----
BRAIN_API_KEY=               # dolu ise /v1/* uclari X-API-Key ister (servis/konsol; JWT de kabul edilir)
DATABASE_URL=                # postgres://...  (aktive: go get pgx && go build -tags pgx)
# DB_DRIVER=pgx
REDIS_URL=                   # redis://...     (aktive: go get go-redis && go build -tags redis)

# ---- Panel kullanici auth (Next.js paneli JWT ile baglanir) ----
BRAIN_JWT_SECRET=            # bos ise her baslangicta rastgele uretilir (dev; restart'ta logout)
BRAIN_JWT_TTL=24h            # erisim token suresi (time.ParseDuration: 24h, 30m...)
BRAIN_REQUIRE_AUTH=false     # true ise /v1/* JWT (veya BRAIN_API_KEY) zorunlu olur
BRAIN_CORS_ORIGINS=          # virgulle ayrilmis izinli origin'ler; orn http://localhost:3001 (bos = *)
BRAIN_ADMIN_EMAIL=admin@disci.local
BRAIN_ADMIN_PASSWORD=admin1234   # ILK calistirmada seed'lenen admin parolasi — PROD'da degistir

# ---- Sunucu / snapshot ----
# BRAIN_ADDR=:8090
# BRAIN_SNAPSHOT=brain-data/snapshot.json
